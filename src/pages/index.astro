---
import '../styles/global.css';

const links = [
  {
    class: 'top-[48.1%]',
    href: 'https://www.instagram.com/ecab.mx?igsh=cDhpeGoycWcyNHhm&utm_source=qr',
    label: 'Abrir Instagram EcabMx',
  },
  {
    class: 'top-[57.8%]',
    href: 'https://wa.me/525532535233',
    label: 'Abrir WhatsApp EcabMx',
  },
  {
    class: 'top-[67.2%]',
    href: '#agenda',
    label: 'Agendar clase EcabMx',
    internal: true,
  },
  {
    class: 'top-[76.7%]',
    href: 'https://maps.app.goo.gl/T1rkvCFSEc2844om8?g_st=ic',
    label: 'Abrir ubicación Club Berimbau',
  },
  {
    class: 'top-[86.1%] w-[76%] h-[8.5%]',
    href: 'https://wa.me/525532535233?text=Hola%20Abdon%2C%20me%20interesa%20recibir%20informaci%C3%B3n%20sobre%20entrenamientos%20en%20l%C3%ADnea%20EcabMx.',
    label: 'Solicitar información sobre entrenamientos en línea',
  },
];

const mantra = 'MENTE × CUERPO × DISCIPLINA × RESULTADOS × ';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EcabMx | S. Abdon Marín — Entrenador de natación y triatlón</title>
    <meta
      name="description"
      content="Entrena con S. Abdon Marín en Club Berimbau, Estado de México. Natación, triatlón y atletismo para todas las edades. Agenda tu clase en línea o a distancia."
    />
    <link rel="canonical" href="https://abdon.mx/" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0a0d08" />
    <meta name="author" content="S. Abdon Marín" />
    <meta name="geo.region" content="MX-MEX" />
    <meta name="geo.placename" content="Club Berimbau, Estado de México" />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content="https://abdon.mx/" />
    <meta property="og:title" content="EcabMx | S. Abdon Marín — Entrenador de natación y triatlón" />
    <meta
      property="og:description"
      content="Natación, triatlón y atletismo para todas las edades en Club Berimbau, Estado de México. Agenda tu clase en línea."
    />
    <meta property="og:image" content="https://abdon.mx/og.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="EcabMx — S. Abdon Marín, entrenador de natación, triatlón y atletismo"
    />
    <meta property="og:site_name" content="EcabMx" />
    <meta property="og:locale" content="es_MX" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="EcabMx | S. Abdon Marín — Entrenador de natación y triatlón" />
    <meta
      name="twitter:description"
      content="Natación, triatlón y atletismo para todas las edades en Club Berimbau, Estado de México. Agenda tu clase en línea."
    />
    <meta name="twitter:image" content="https://abdon.mx/og.jpg" />
    <meta
      name="twitter:image:alt"
      content="EcabMx — S. Abdon Marín, entrenador de natación, triatlón y atletismo"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'ProfilePage',
            '@id': 'https://abdon.mx/#page',
            url: 'https://abdon.mx/',
            name: 'EcabMx | S. Abdon Marín — Entrenador de natación y triatlón',
            inLanguage: 'es-MX',
            mainEntity: { '@id': 'https://abdon.mx/#person' },
            about: { '@id': 'https://abdon.mx/#person' },
            isPartOf: { '@id': 'https://abdon.mx/#website' },
            primaryImageOfPage: 'https://abdon.mx/og.jpg',
          },
          {
            '@type': 'WebSite',
            '@id': 'https://abdon.mx/#website',
            url: 'https://abdon.mx/',
            name: 'EcabMx',
            inLanguage: 'es-MX',
            publisher: { '@id': 'https://abdon.mx/#person' },
          },
          {
            '@type': 'Person',
            '@id': 'https://abdon.mx/#person',
            name: 'S. Abdon Marín',
            alternateName: 'EcabMx',
            jobTitle: 'Entrenador multidisciplinario de natación, triatlón y atletismo',
            description:
              'Entrenador de natación, triatlón y atletismo. Formación y alto rendimiento para todas las edades. Entrenador Máster en el Estado de México, Club Berimbau.',
            image: 'https://abdon.mx/og.jpg',
            url: 'https://abdon.mx/',
            telephone: '+52-55-3253-5233',
            sameAs: ['https://www.instagram.com/ecab.mx'],
            knowsLanguage: 'es-MX',
            knowsAbout: [
              'Natación',
              'Triatlón',
              'Atletismo',
              'Alto rendimiento deportivo',
              'Técnica de nado',
              'Entrenamiento personalizado',
            ],
            worksFor: { '@id': 'https://abdon.mx/#business' },
            workLocation: { '@id': 'https://abdon.mx/#business' },
          },
          {
            '@type': ['LocalBusiness', 'SportsActivityLocation'],
            '@id': 'https://abdon.mx/#business',
            name: 'EcabMx — Entrenamiento con S. Abdon Marín',
            description:
              'Clases de natación, triatlón y atletismo para todas las edades en Club Berimbau, Estado de México. También entrenamientos en línea con programas personalizados.',
            url: 'https://abdon.mx/',
            image: 'https://abdon.mx/og.jpg',
            telephone: '+52-55-3253-5233',
            priceRange: '$$',
            currenciesAccepted: 'MXN',
            areaServed: [
              { '@type': 'AdministrativeArea', name: 'Estado de México' },
              { '@type': 'Country', name: 'México' },
            ],
            address: {
              '@type': 'PostalAddress',
              addressLocality: 'Club Berimbau',
              addressRegion: 'Estado de México',
              addressCountry: 'MX',
            },
            hasMap: 'https://maps.app.goo.gl/T1rkvCFSEc2844om8',
            sameAs: ['https://www.instagram.com/ecab.mx'],
            employee: { '@id': 'https://abdon.mx/#person' },
            hasOfferCatalog: {
              '@type': 'OfferCatalog',
              name: 'Entrenamientos EcabMx',
              itemListElement: [
                {
                  '@type': 'Offer',
                  itemOffered: {
                    '@type': 'Service',
                    name: 'Clases de natación',
                    serviceType: 'Entrenamiento de natación',
                    description:
                      'Clases presenciales de natación para todas las edades: iniciación, técnica y alto rendimiento.',
                    provider: { '@id': 'https://abdon.mx/#business' },
                  },
                },
                {
                  '@type': 'Offer',
                  itemOffered: {
                    '@type': 'Service',
                    name: 'Entrenamiento de triatlón',
                    serviceType: 'Entrenamiento de triatlón',
                    description:
                      'Preparación de triatlón: natación, ciclismo y carrera con planificación por objetivos.',
                    provider: { '@id': 'https://abdon.mx/#business' },
                  },
                },
                {
                  '@type': 'Offer',
                  itemOffered: {
                    '@type': 'Service',
                    name: 'Entrenamiento en línea',
                    serviceType: 'Entrenamiento a distancia',
                    description:
                      'Programas personalizados a distancia con seguimiento continuo y ajustes por progreso.',
                    provider: { '@id': 'https://abdon.mx/#business' },
                  },
                },
              ],
            },
          },
        ],
      })}
    />
    <link
      rel="preload"
      as="image"
      href="/assets/ecabmx-diseno.webp"
      type="image/webp"
      fetchpriority="high"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://nadamas.app" />
    {/* Fonts load async so they never block first paint; noscript keeps them for JS-less clients. */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;900&display=swap"
      />
    </noscript>
    <style>
      :root {
        --acid: #b7ff00;
        --ink: #0a0d08;
      }
      body {
        font-family: 'Archivo', Arial, Helvetica, sans-serif;
      }
      /* Pool-lane texture: faint vertical lines across the desktop backdrop. */
      .lanes {
        background-image: repeating-linear-gradient(
          90deg,
          transparent 0,
          transparent 138px,
          rgb(255 255 255 / 0.04) 138px,
          rgb(255 255 255 / 0.04) 140px
        );
      }
      /* Vertical mantra ticker along the page edge. */
      @keyframes mantra-scroll {
        from {
          transform: translateY(0);
        }
        to {
          transform: translateY(-50%);
        }
      }
      .mantra-track {
        animation: mantra-scroll 60s linear infinite;
      }
      @media (prefers-reduced-motion: reduce) {
        .mantra-track {
          animation: none;
        }
      }
    </style>
  </head>
  <body class="lanes min-h-screen bg-[var(--ink)] text-white">
    <!-- Edge mantra: the image's own manifesto, running down the margin (desktop only). -->
    <aside
      aria-hidden="true"
      class="pointer-events-none fixed inset-y-0 left-6 hidden w-6 overflow-hidden xl:block"
    >
      <div
        class="mantra-track whitespace-nowrap text-[11px] font-bold tracking-[0.5em] text-white/25 [writing-mode:vertical-rl]"
      >
        {mantra.repeat(4) + mantra.repeat(4)}
      </div>
    </aside>

    <main
      class="mx-auto w-full max-w-[430px] lg:grid lg:max-w-[1060px] lg:grid-cols-[430px_minmax(360px,1fr)] lg:items-start lg:gap-14 lg:px-8 lg:py-14 xl:gap-20"
      aria-label="EcabMx enlaces"
    >
      <h1 class="sr-only">
        EcabMx — S. Abdon Marín, entrenador de natación, triatlón y atletismo en Club Berimbau,
        Estado de México
      </h1>
      <div
        class="relative lg:overflow-hidden lg:rounded-3xl lg:ring-1 lg:ring-white/10 lg:shadow-[0_40px_120px_-40px_rgb(183_255_0_/_0.25)]"
      >
        <picture>
          <source srcset="/assets/ecabmx-diseno.webp" type="image/webp" />
          <img
            class="block h-auto w-full select-none"
            src="/assets/ecabmx-diseno.png"
            alt="EcabMx - S. Abdon Marín, entrenador multidisciplinario, junto a la alberca de Club Berimbau con enlaces a Instagram, WhatsApp y agenda de clases"
            width="863"
            height="1823"
            fetchpriority="high"
            draggable="false"
          />
        </picture>
        {
          links.map((link) => (
            <a
              class:list={[
                'absolute left-[5.7%] h-[7.1%] w-[56%] cursor-pointer rounded-3xl focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--acid)]',
                link.class,
              ]}
              href={link.href}
              target={link.internal ? undefined : '_blank'}
              rel={link.internal ? undefined : 'noopener'}
              aria-label={link.label}
            />
          ))
        }
      </div>
      <div class="sr-only">
        <h2>Contacto y entrenamientos EcabMx</h2>
        <ul>
          <li>Instagram: @ecab.mx</li>
          <li>WhatsApp: +52 55 3253 5233</li>
          <li>Clases presenciales en Club Berimbau, Estado de México</li>
          <li>Entrenamientos en línea: programas personalizados, seguimiento y resultados reales</li>
        </ul>
      </div>

      <section
        id="agenda"
        class="scroll-mt-4 px-4 pb-10 lg:sticky lg:top-14 lg:px-0 lg:pb-0"
        aria-label="Agenda de clases"
      >
        <header class="hidden lg:block">
          <p class="text-xs font-bold tracking-[0.35em] text-[var(--acid)]">AGENDA EN LÍNEA</p>
          <h2 class="mt-3 text-4xl font-black leading-none tracking-tight">
            Reserva tu<br />clase<span class="text-[var(--acid)]">.</span>
          </h2>
          <p class="mt-4 max-w-sm text-sm font-medium leading-relaxed text-white/60">
            Elige un horario y entrena con S. Abdon Marín en Club Berimbau — natación, triatlón y
            atletismo para todas las edades.
          </p>
          <div class="mb-6 mt-8 h-px w-full bg-gradient-to-r from-[var(--acid)]/60 via-white/15 to-transparent">
          </div>
        </header>

        <div
          class="lg:overflow-hidden lg:rounded-2xl lg:ring-1 lg:ring-white/10"
          data-nadamas-widget
          data-cliente="hJ3lwzAlTkQkaMev2ro8Of129d83"
          data-theme="dark"
          data-title="Horarios EcabMx en nadamas.app"
        >
        </div>
        <script src="https://nadamas.app/widget.js" async is:inline></script>

        <footer class="mt-8 hidden items-center gap-3 text-[11px] font-bold tracking-[0.35em] text-white/35 lg:flex">
          <span class="h-px w-8 bg-[var(--acid)]/60"></span>
          DISCIPLINA, TÉCNICA Y PROGRESO
        </footer>
      </section>

      <section
        class="border-t border-white/10 px-4 pb-16 pt-12 lg:col-span-2 lg:px-0 lg:pt-16"
        aria-labelledby="sobre-titulo"
      >
        <p class="text-xs font-bold tracking-[0.35em] text-[var(--acid)]">ENTRENAMIENTO</p>
        <h2 id="sobre-titulo" class="mt-3 text-3xl font-black leading-none tracking-tight lg:text-4xl">
          Natación, triatlón y atletismo<br class="hidden lg:block" /> en el Estado de México
        </h2>
        <div class="mt-6 grid gap-10 text-sm font-medium leading-relaxed text-white/70 lg:grid-cols-3">
          <div>
            <h3 class="mb-2 text-base font-black text-white">Quién entrena</h3>
            <p>
              S. Abdon Marín es entrenador multidisciplinario y Entrenador Máster con base en Club
              Berimbau, Estado de México. Trabaja con nadadores desde iniciación hasta alto
              rendimiento, y con triatletas y corredores que preparan una competencia concreta.
            </p>
          </div>
          <div>
            <h3 class="mb-2 text-base font-black text-white">Qué incluye</h3>
            <p>
              Clases presenciales de natación para todas las edades, corrección de técnica de nado,
              preparación de triatlón (natación, ciclismo y carrera) y atletismo. También hay
              entrenamientos en línea: programas personalizados, seguimiento continuo y ajustes
              según tu progreso.
            </p>
          </div>
          <div>
            <h3 class="mb-2 text-base font-black text-white">Cómo empezar</h3>
            <p>
              Reserva un horario en la
              <a class="text-[var(--acid)] underline underline-offset-4" href="#agenda">agenda en línea</a>
              o escribe por
              <a
                class="text-[var(--acid)] underline underline-offset-4"
                href="https://wa.me/525532535233"
                target="_blank"
                rel="noopener">WhatsApp al +52 55 3253 5233</a
              >. Para ver el día a día del club, sigue
              <a
                class="text-[var(--acid)] underline underline-offset-4"
                href="https://www.instagram.com/ecab.mx"
                target="_blank"
                rel="noopener">@ecab.mx en Instagram</a
              >.
            </p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

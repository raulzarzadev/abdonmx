---
import '../styles/global.css';

const links = [
  {
    class: 'top-[48.1%]',
    href: 'https://www.instagram.com/ecab.mx?igsh=cDhpeGoycWcyNHhm&utm_source=qr',
    label: 'Abrir Instagram EcabMx',
  },
  {
    class: 'top-[57.8%]',
    href: 'https://wa.me/525532535233',
    label: 'Abrir WhatsApp EcabMx',
  },
  {
    class: 'top-[67.2%]',
    href: '#agenda',
    label: 'Agendar clase EcabMx',
    internal: true,
  },
  {
    class: 'top-[76.7%]',
    href: 'https://maps.app.goo.gl/T1rkvCFSEc2844om8?g_st=ic',
    label: 'Abrir ubicación Club Berimbau',
  },
  {
    class: 'top-[86.1%] w-[76%] h-[8.5%]',
    href: 'https://wa.me/525532535233?text=Hola%20Abdon%2C%20me%20interesa%20recibir%20informaci%C3%B3n%20sobre%20entrenamientos%20en%20l%C3%ADnea%20EcabMx.',
    label: 'Solicitar información sobre entrenamientos en línea',
  },
];

const mantra = 'MENTE × CUERPO × DISCIPLINA × RESULTADOS × ';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EcabMx | S. Abdon Marín — Entrenador de natación y triatlón</title>
    <meta
      name="description"
      content="Entrena con S. Abdon Marín en Club Berimbau, Estado de México. Natación, triatlón y atletismo para todas las edades. Agenda tu clase en línea o a distancia."
    />
    <link rel="canonical" href="https://abdon.mx/" />
    <meta name="theme-color" content="#0a0d08" />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content="https://abdon.mx/" />
    <meta property="og:title" content="EcabMx | S. Abdon Marín — Entrenador de natación y triatlón" />
    <meta
      property="og:description"
      content="Natación, triatlón y atletismo para todas las edades en Club Berimbau, Estado de México. Agenda tu clase en línea."
    />
    <meta property="og:image" content="https://abdon.mx/assets/ecabmx-diseno.png" />
    <meta property="og:image:width" content="863" />
    <meta property="og:image:height" content="1823" />
    <meta property="og:locale" content="es_MX" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="EcabMx | S. Abdon Marín — Entrenador de natación y triatlón" />
    <meta
      name="twitter:description"
      content="Natación, triatlón y atletismo para todas las edades en Club Berimbau, Estado de México. Agenda tu clase en línea."
    />
    <meta name="twitter:image" content="https://abdon.mx/assets/ecabmx-diseno.png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'ProfilePage',
        url: 'https://abdon.mx/',
        inLanguage: 'es-MX',
        mainEntity: {
          '@type': 'Person',
          name: 'S. Abdon Marín',
          alternateName: 'EcabMx',
          jobTitle: 'Entrenador multidisciplinario',
          description:
            'Entrenador de natación, triatlón y atletismo. Formación y alto rendimiento para todas las edades. Entrenador Máster en el Estado de México, Club Berimbau.',
          image: 'https://abdon.mx/assets/ecabmx-diseno.png',
          url: 'https://abdon.mx/',
          sameAs: ['https://www.instagram.com/ecab.mx'],
          knowsAbout: ['Natación', 'Triatlón', 'Atletismo', 'Alto rendimiento deportivo'],
          workLocation: {
            '@type': 'Place',
            name: 'Club Berimbau',
            address: {
              '@type': 'PostalAddress',
              addressRegion: 'Estado de México',
              addressCountry: 'MX',
            },
          },
        },
      })}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;900&display=swap"
    />
    <style>
      :root {
        --acid: #b7ff00;
        --ink: #0a0d08;
      }
      body {
        font-family: 'Archivo', Arial, Helvetica, sans-serif;
      }
      /* Pool-lane texture: faint vertical lines across the desktop backdrop. */
      .lanes {
        background-image: repeating-linear-gradient(
          90deg,
          transparent 0,
          transparent 138px,
          rgb(255 255 255 / 0.04) 138px,
          rgb(255 255 255 / 0.04) 140px
        );
      }
      /* Vertical mantra ticker along the page edge. */
      @keyframes mantra-scroll {
        from {
          transform: translateY(0);
        }
        to {
          transform: translateY(-50%);
        }
      }
      .mantra-track {
        animation: mantra-scroll 60s linear infinite;
      }
      @media (prefers-reduced-motion: reduce) {
        .mantra-track {
          animation: none;
        }
      }
    </style>
  </head>
  <body class="lanes min-h-screen bg-[var(--ink)] text-white">
    <!-- Edge mantra: the image's own manifesto, running down the margin (desktop only). -->
    <aside
      aria-hidden="true"
      class="pointer-events-none fixed inset-y-0 left-6 hidden w-6 overflow-hidden xl:block"
    >
      <div
        class="mantra-track whitespace-nowrap text-[11px] font-bold tracking-[0.5em] text-white/25 [writing-mode:vertical-rl]"
      >
        {mantra.repeat(4) + mantra.repeat(4)}
      </div>
    </aside>

    <main
      class="mx-auto w-full max-w-[430px] lg:grid lg:max-w-[1060px] lg:grid-cols-[430px_minmax(360px,1fr)] lg:items-start lg:gap-14 lg:px-8 lg:py-14 xl:gap-20"
      aria-label="EcabMx enlaces"
    >
      <h1 class="sr-only">
        EcabMx — S. Abdon Marín, entrenador de natación, triatlón y atletismo en Club Berimbau,
        Estado de México
      </h1>
      <div
        class="relative lg:overflow-hidden lg:rounded-3xl lg:ring-1 lg:ring-white/10 lg:shadow-[0_40px_120px_-40px_rgb(183_255_0_/_0.25)]"
      >
        <picture>
          <source srcset="/assets/ecabmx-diseno.webp" type="image/webp" />
          <img
            class="block h-auto w-full select-none"
            src="/assets/ecabmx-diseno.png"
            alt="EcabMx - S. Abdon Marín, entrenador multidisciplinario, junto a la alberca de Club Berimbau con enlaces a Instagram, WhatsApp y agenda de clases"
            width="863"
            height="1823"
            fetchpriority="high"
            draggable="false"
          />
        </picture>
        {
          links.map((link) => (
            <a
              class:list={[
                'absolute left-[5.7%] h-[7.1%] w-[56%] cursor-pointer rounded-3xl focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--acid)]',
                link.class,
              ]}
              href={link.href}
              target={link.internal ? undefined : '_blank'}
              rel={link.internal ? undefined : 'noopener'}
              aria-label={link.label}
            />
          ))
        }
      </div>
      <div class="sr-only">
        <h2>Contacto y entrenamientos EcabMx</h2>
        <ul>
          <li>Instagram: @ecab.mx</li>
          <li>WhatsApp: +52 55 3253 5233</li>
          <li>Clases presenciales en Club Berimbau, Estado de México</li>
          <li>Entrenamientos en línea: programas personalizados, seguimiento y resultados reales</li>
        </ul>
      </div>

      <section
        id="agenda"
        class="scroll-mt-4 px-4 pb-10 lg:sticky lg:top-14 lg:px-0 lg:pb-0"
        aria-label="Agenda de clases"
      >
        <header class="hidden lg:block">
          <p class="text-xs font-bold tracking-[0.35em] text-[var(--acid)]">AGENDA EN LÍNEA</p>
          <h2 class="mt-3 text-4xl font-black leading-none tracking-tight">
            Reserva tu<br />clase<span class="text-[var(--acid)]">.</span>
          </h2>
          <p class="mt-4 max-w-sm text-sm font-medium leading-relaxed text-white/60">
            Elige un horario y entrena con S. Abdon Marín en Club Berimbau — natación, triatlón y
            atletismo para todas las edades.
          </p>
          <div class="mb-6 mt-8 h-px w-full bg-gradient-to-r from-[var(--acid)]/60 via-white/15 to-transparent">
          </div>
        </header>

        <div
          class="lg:overflow-hidden lg:rounded-2xl lg:ring-1 lg:ring-white/10"
          data-nadamas-widget
          data-cliente="hJ3lwzAlTkQkaMev2ro8Of129d83"
          data-theme="dark"
          data-title="Horarios EcabMx en nadamas.app"
        >
        </div>
        <script src="https://nadamas.app/widget.js" async is:inline></script>

        <footer class="mt-8 hidden items-center gap-3 text-[11px] font-bold tracking-[0.35em] text-white/35 lg:flex">
          <span class="h-px w-8 bg-[var(--acid)]/60"></span>
          DISCIPLINA, TÉCNICA Y PROGRESO
        </footer>
      </section>
    </main>
  </body>
</html>
